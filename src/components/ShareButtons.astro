---
// ShareButtons.astro — native share + social share buttons
const currentUrl = Astro.url.href;
const rawTitle = Astro.props.title || 'mooma.online';
const shareText = `บทความนี้น่าจะมีประโยชน์กับทาสหมาแมว: ${rawTitle}`;
const encodedUrl = encodeURIComponent(currentUrl);
const encodedTitle = encodeURIComponent(`${rawTitle} | mooma.online`);
const encodedShareText = encodeURIComponent(shareText);
---

<section
  class="share-section"
  id="share-section"
  aria-labelledby="share-heading"
  data-share-url={currentUrl}
  data-share-title={rawTitle}
  data-share-text={shareText}
>
  <div class="share-card">
    <div class="share-heading-row">
      <div>
        <p class="share-kicker">แชร์เก็บไว้ / ส่งให้เพื่อน</p>
        <h2 class="share-heading" id="share-heading">บทความนี้มีประโยชน์? แชร์ต่อได้ในคลิกเดียว</h2>
        <p class="share-subtitle">เหมาะสำหรับส่งให้เพื่อนทาสหมาแมว หรือเก็บลิงก์ไว้อ่านซ้ำตอนเลือกซื้อของให้สัตว์เลี้ยง</p>
      </div>
      <span class="share-icon" aria-hidden="true">🐾</span>
    </div>

    <div class="share-buttons" role="list" aria-label="ช่องทางแชร์บทความ">
      <button
        class="share-btn share-native"
        type="button"
        data-native-share
        role="listitem"
        aria-label="แชร์ด้วยเมนูของมือถือหรือคอมพิวเตอร์"
        title="แชร์ด้วยเมนูของเครื่อง"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="m8.6 13.5 6.8 4"/><path d="m15.4 6.5-6.8 4"/></svg>
        <span>แชร์ทันที</span>
      </button>

      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-fb"
        aria-label="แชร์ไป Facebook"
        title="แชร์ไป Facebook"
        role="listitem"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
        <span>Facebook</span>
      </a>

      <a
        href={`https://social-plugins.line.me/lineit/share?url=${encodedUrl}&text=${encodedShareText}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-line"
        aria-label="แชร์ไป LINE"
        title="แชร์ไป LINE"
        role="listitem"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.365 9.863a.631.631 0 0 1 0 1.261H17.61v1.125h1.755a.63.63 0 0 1 0 1.26h-2.386a.633.633 0 0 1-.626-.636V10.5a.633.633 0 0 1 .626-.637h2.386zm-8.108-.002c.344 0 .62.277.633.618v3.127a.633.633 0 0 1-.637.636h-.449l-.002-.002a.594.594 0 0 1-.333.195l-.834.416a.13.13 0 0 1-.194-.12v-.49h-.002a.623.623 0 0 1-.623-.635v-3.127a.63.63 0 0 1 .63-.618zm-3.253.001a.63.63 0 0 1 .62.649v.96h1.384v-.96c0-.36.285-.65.63-.65s.631.29.631.65v3.126a.626.626 0 0 1-1.258.004v-1.554H8.624v1.553a.626.626 0 0 1-1.258-.003V10.511c0-.358.279-.649.63-.649zm12.982-5.738C23.19 5.886 24 7.9 24 10.36c0 4.1-3.613 7.424-8.12 7.32-.345-.006-.683.085-.973.28l-2.498 1.527a.314.314 0 0 1-.476-.266v-1.853c-6.438.082-9.933-2.316-9.933-5.013 0-2.835 2.93-5.13 6.546-5.13h12.44v.001z"/></svg>
        <span>LINE</span>
      </a>

      <a
        href={`https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`}
        target="_blank"
        rel="noopener noreferrer"
        class="share-btn share-x"
        aria-label="แชร์ไป X"
        title="แชร์ไป X"
        role="listitem"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        <span>X</span>
      </a>

      <button
        class="share-btn share-copy"
        type="button"
        data-copy-share
        role="listitem"
        aria-label="คัดลอกลิงก์"
        title="คัดลอกลิงก์ไว้ส่งต่อ"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        <span data-copy-label>คัดลอกลิงก์</span>
      </button>
    </div>

    <p class="share-hint">ทิป: บนมือถือปุ่ม “แชร์ทันที” จะเปิดเมนูแชร์ของเครื่อง ส่วน “คัดลอกลิงก์” ใช้ส่งในแชตหรือ Story ได้เร็วที่สุด</p>
    <span class="share-copied-msg" id="share-copied-msg" role="status" aria-live="polite">คัดลอกลิงก์แล้ว ✅</span>
  </div>
</section>

<script is:inline>
  (function() {
    const section = document.getElementById('share-section');
    if (!section) return;

    const shareData = {
      title: section.dataset.shareTitle || document.title,
      text: section.dataset.shareText || document.title,
      url: section.dataset.shareUrl || window.location.href,
    };
    const nativeBtn = section.querySelector('[data-native-share]');
    const copyBtn = section.querySelector('[data-copy-share]');
    const copyLabel = section.querySelector('[data-copy-label]');
    const msg = section.querySelector('#share-copied-msg');

    function showMessage(text) {
      if (!msg) return;
      msg.textContent = text;
      msg.classList.add('share-copied-msg--show');
      window.clearTimeout(showMessage.timer);
      showMessage.timer = window.setTimeout(() => {
        msg.classList.remove('share-copied-msg--show');
      }, 2200);
    }

    async function copyShareLink() {
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(shareData.url);
        } else {
          const ta = document.createElement('textarea');
          ta.value = shareData.url;
          ta.setAttribute('readonly', '');
          ta.style.position = 'fixed';
          ta.style.inset = '0 auto auto 0';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        showMessage('คัดลอกลิงก์แล้ว ✅');
        if (copyBtn) copyBtn.classList.add('share-copy--done');
        if (copyLabel) copyLabel.textContent = 'คัดลอกแล้ว';
        window.clearTimeout(copyShareLink.timer);
        copyShareLink.timer = window.setTimeout(() => {
          if (copyBtn) copyBtn.classList.remove('share-copy--done');
          if (copyLabel) copyLabel.textContent = 'คัดลอกลิงก์';
        }, 2200);
      } catch (error) {
        showMessage('คัดลอกไม่สำเร็จ ลองกดแชร์ทันทีแทน');
      }
    }

    if (nativeBtn) {
      if (!navigator.share) {
        nativeBtn.classList.add('share-native--hidden');
      } else {
        nativeBtn.addEventListener('click', async () => {
          try {
            await navigator.share(shareData);
          } catch (error) {
            if (error && error.name !== 'AbortError') copyShareLink();
          }
        });
      }
    }

    if (copyBtn) {
      copyBtn.addEventListener('click', copyShareLink);
    }

    section.querySelectorAll('a.share-btn').forEach((link) => {
      link.addEventListener('click', (event) => {
        const isSmallScreen = window.matchMedia('(max-width: 760px)').matches;
        if (isSmallScreen) return;
        event.preventDefault();
        const width = 640;
        const height = 620;
        const left = Math.max(0, window.screenX + (window.outerWidth - width) / 2);
        const top = Math.max(0, window.screenY + (window.outerHeight - height) / 2);
        window.open(
          link.href,
          'mooma-share',
          `noopener,noreferrer,width=${width},height=${height},left=${left},top=${top}`,
        );
      });
    });
  })();
</script>
