---
const signupUrl = 'https://s.shopee.co.th/1VwEXkOIIH';
---

<section class="shopee-signup-cta" aria-label="สมัคร Shopee สำหรับลูกค้าใหม่">
  <a href={signupUrl} class="btn-card btn-card-shopee shopee-signup-button" target="_blank" rel="nofollow sponsored">
    สมัคร Shopee รับสิทธิพิเศษลูกค้าใหม่
  </a>
  <p>โหลดแอป Shopee พร้อมสั่งซื้อครั้งแรก เพื่อรับสิทธิพิเศษสำหรับลูกค้าใหม่</p>
</section>

<style>
  .shopee-signup-cta {
    margin: 24px 0 8px;
    padding: 18px;
    border: 1px solid #ffd6c7;
    border-radius: 16px;
    background: linear-gradient(135deg, #fff7f2, #fff);
    text-align: center;
  }

  .shopee-signup-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.05em;
    padding: 13px 24px;
  }

  .shopee-signup-cta p {
    margin: 10px 0 0;
    color: var(--gray-400);
    font-size: 0.92em;
    line-height: 1.6;
  }
</style>
