---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import productsData from '../data/products.json';
import { homePageSchema } from '../utils/structuredData';

const featured = productsData.products.filter(p => p.featured).sort((a, b) => a.priority - b.priority);
const categoryLabels = {
  'dog-food': 'อาหารสุนัข',
  'cat-food': 'อาหารแมว',
  'dog-treats': 'ขนมสุนัข',
  'cat-litter': 'กระบะทรายแมว',
  'cat-condo': 'คอนโดแมว / ของเล่น',
  'smart-pet': 'Smart Pet Gadgets',
  'supplements': 'อาหารเสริมสัตว์เลี้ยง',
  'grooming': 'กรูมมิ่ง & ดูแลสุขอนามัย',
};
const orgData = homePageSchema(featured);
---

<Layout
  title="mooma.online — รีวิวของใช้หมาแมว จาก Shopee คัดมาแล้วว่าคุ้มจริง"
  description="รีวิวของใช้หมาแมว จาก Shopee ที่คัดมาแล้วว่าคุ้มจริง เปรียบเทียบง่าย อ่านไว เหมาะกับเจ้าของสัตว์เลี้ยงที่อยากซื้อของดี ไม่เสียเงินมั่ว"
  ogTitle="mooma.online — รีวิวของใช้หมาแมว คัดมาแล้วว่าคุ้มจริง"
  ogDescription="เปรียบเทียบง่าย อ่านไว เหมาะกับเจ้าของสัตว์เลี้ยงที่อยากซื้อของดี ไม่เสียเงินมั่ว"
  ogUrl="https://mooma.online"
  structuredData={orgData}
>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">🐾 ไม่มีค่าใช้จ่าย · อ่านรีวิวได้ไม่จำกัด</div>
  <h1>รีวิวของใช้หมาแมว จาก Shopee<br>ที่<span>คัดมาแล้วว่าคุ้มจริง</span></h1>
  <p class="hero-sub">เปรียบเทียบง่าย อ่านไว เหมาะกับเจ้าของสัตว์เลี้ยงที่อยากซื้อของดี ไม่เสียเงินมั่ว</p>
  <div class="hero-ctas">
    <a href="#products" class="btn-primary">🐾 ดูสินค้าแนะนำ — ฟรี</a>
    <a href="#categories" class="btn-outline">📂 เลือกตามหมวดหมู่</a>
  </div>
  <div class="trust-row">
    <div class="trust-item"><span class="trust-dot"></span>เปรียบเทียบง่าย</div>
    <div class="trust-item"><span class="trust-dot"></span>ซื้อตามได้จริง</div>
    <div class="trust-item"><span class="trust-dot"></span>ไม่เสียเงินมั่ว</div>
  </div>
</section>

<!-- FEATURED PRODUCTS (data-driven) -->
<section class="section" id="products">
  <div class="section-header">
    <h2>🛒 สินค้าแนะนำ</h2>
    <p>คัดมาแล้วว่าคุ้มค่าที่สุด สำหรับน้องหมาน้องแมวของคุณ</p>
    <p style="font-size:0.82em;color:var(--gray-400);margin-top:6px">หมายเหตุ: บางลิงก์เป็น Affiliate — อ่านเพิ่มเติม<a href="/disclosure" style="color:var(--coral)">ที่นี่</a></p>
  </div>
  <div class="product-grid">
    {featured.map(p => (
      <ProductCard
        href={`/products/${p.slug}`}
        shopeeUrl={p.shopeeUrl}
        emoji={p.emoji}
        badge={p.badge}
        badgeClass={p.badgeClass}
        image={p.image || undefined}
        title={p.title}
        suitable={p.suitable}
        highlight={p.highlight}
        note={p.note}
        stars={p.stars}
        variant="homepage"
      />
    ))}
  </div>
</section>

<!-- CATEGORIES -->
<section class="section" id="categories">
  <div class="section-header">
    <h2>📂 เลือกดูตามหมวดหมู่</h2>
    <p>หาของที่เหมาะกับน้องแบบง่ายๆ</p>
  </div>
  <div class="cat-grid">
    <a href="/category/dog-food" class="cat-card">
      <div class="cat-icon">🍖</div><h4>อาหารสุนัข</h4><p>อาหารเม็ด เปียก เกรนฟรี</p>
    </a>
    <a href="/category/cat-food" class="cat-card">
      <div class="cat-icon">🐟</div><h4>อาหารแมว</h4><p>พรีเมียม โปรตีนสูง</p>
    </a>
    <a href="/category/dog-treats" class="cat-card">
      <div class="cat-icon">🦴</div><h4>ขนมสุนัข</h4><p>ขัดฟัน ฝึก เป็นรางวัล</p>
    </a>
    <a href="/category/cat-litter" class="cat-card">
      <div class="cat-icon">🚽</div><h4>กระบะทราย / ห้องน้ำแมว</h4><p>UV ระบบปิด เก็บกลิ่น</p>
    </a>
    <a href="/category/cat-condo" class="cat-card">
      <div class="cat-icon">🏰</div><h4>คอนโดแมว / ของเล่น</h4><p>ติดผนัง ต้นไม้ ลับเล็บ</p>
    </a>
    <a href="/category/smart-pet" class="cat-card">
      <div class="cat-icon">🤖</div><h4>Smart Pet Gadgets</h4><p>น้ำพุ เครื่องให้อาหาร</p>
    </a>
    <a href="/category/supplements" class="cat-card">
      <div class="cat-icon">💊</div><h4>อาหารเสริมสัตว์เลี้ยง</h4><p>บำรุงขน ข้อต่อ ภูมิคุ้มกัน</p>
    </a>
    <a href="/category/grooming" class="cat-card">
      <div class="cat-icon">✂️</div><h4>กรูมมิ่ง & ดูแลสุขอนามัย</h4><p>แผ่นเช็ด ยาหยดหลัง แชมพู</p>
    </a>
  </div>
</section>

<!-- DECISION HELPER -->
<section class="section">
  <div class="section-header">
    <h2>🎯 เลือกของให้เหมาะกับน้องแบบง่ายๆ</h2>
    <p>กรองตามความต้องการของคุณ</p>
  </div>
  <div class="filter-section">
    <div class="filter-chips">
      <span class="chip active">🐶 สำหรับหมา</span>
      <span class="chip">🐱 สำหรับแมว</span>
      <span class="chip">💰 งบประหยัด</span>
      <span class="chip">🔥 ขายดี</span>
      <span class="chip">🧹 ดูแลง่าย</span>
      <span class="chip">🏢 บ้านพื้นที่น้อย</span>
      <span class="chip">👃 กลิ่นน้อย</span>
      <span class="chip">🤖 Smart Pet</span>
    </div>
    <p style="margin-top:20px;color:var(--gray-600);font-size:0.9em">💡 เลือก filter ด้านบน แล้วเราจะคัดสินค้าที่เหมาะกับคุณให้ — หรือ <a href="#products" style="color:var(--coral);font-weight:600">ดูสินค้าทั้งหมด</a></p>
  </div>
</section>

<!-- RECOMMENDED ARTICLES -->
<section class="section" id="articles">
  <div class="section-header">
    <h2>📚 บทความแนะนำสำหรับทาสหมาแมว</h2>
    <p>คู่มือแก้ปัญหาจริงในบ้าน — อ่านก่อนเลือกของให้เหมาะกับน้อง</p>
  </div>
  <div class="review-grid">
    <article class="review-card">
      <div class="review-thumb" style="background:linear-gradient(135deg,#FFF0EB,#FFF7E6)">🐶</div>
      <div class="review-body">
        <div class="review-cat">คู่มือสุนัข · เบื่ออาหาร</div>
        <h4>หมาไม่ค่อยกินข้าว ทำยังไงดี?</h4>
        <p>ไล่เช็กสุขภาพ พฤติกรรม กลิ่นอาหาร ตารางมื้อ และวิธีเปลี่ยนอาหารให้เหมาะกับน้องหมา</p>
        <div class="review-meta">
          <span class="read-time">⏱ 7 นาที</span>
          <a href="/articles/dog-not-eating-guide" class="read-link">อ่านคู่มือ →</a>
        </div>
      </div>
    </article>
    <article class="review-card">
      <div class="review-thumb" style="background:linear-gradient(135deg,#FFF5F0,#F5F0FF)">🦷</div>
      <div class="review-body">
        <div class="review-cat">คู่มือสุนัข · ช่องปาก</div>
        <h4>ขนมขัดฟันสุนัขจำเป็นไหม?</h4>
        <p>ดูวิธีเลือกขนาด เนื้อสัมผัส ส่วนผสม และข้อควรระวังเมื่อต้องดูแลคราบฟันน้องหมา</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/dog-dental-chews-guide" class="read-link">อ่านคู่มือ →</a>
        </div>
      </div>
    </article>
    <article class="review-card">
      <div class="review-thumb" style="background:linear-gradient(135deg,#EBF7FF,#E8F5E9)">😬</div>
      <div class="review-body">
        <div class="review-cat">คู่มือสุนัข · กลิ่นปาก</div>
        <h4>หมากลิ่นปากแรง แก้ยังไง?</h4>
        <p>เช็กสาเหตุจากฟัน เหงือก อาหาร และสัญญาณที่ควรให้สัตวแพทย์ตรวจช่องปาก</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/dog-bad-breath-solution" class="read-link">อ่านคู่มือ →</a>
        </div>
      </div>
    </article>
    <article class="review-card">
      <div class="review-thumb" style="background:linear-gradient(135deg,#E8F5E9,#FFF7E6)">👃</div>
      <div class="review-body">
        <div class="review-cat">คู่มือแมว · กลิ่นในบ้าน</div>
        <h4>แมวฉี่เหม็นมาก แก้ยังไง?</h4>
        <p>ไล่เช็กต้นเหตุกลิ่นฉี่แมว ตั้งแต่กระบะ ทราย จุดวาง ไปจนถึงสัญญาณสุขภาพที่ไม่ควรมองข้าม</p>
        <div class="review-meta">
          <span class="read-time">⏱ 7 นาที</span>
          <a href="/articles/cat-pee-smell-solution" class="read-link">อ่านคู่มือ →</a>
        </div>
      </div>
    </article>
    <article class="review-card">
      <div class="review-thumb" style="background:linear-gradient(135deg,#F5F0FF,#EBF7FF)">🐟</div>
      <div class="review-body">
        <div class="review-cat">อาหารแมว · ผิวหนังและขน</div>
        <h4>อาหารแมวช่วยเรื่องขนร่วง ผิวหนัง และขนสวย เลือกยังไงดี</h4>
        <p>เช็กสารอาหารสำคัญ โปรตีน โอเมก้า ไบโอติน Zinc และวิธีอ่านฉลากแบบไม่หลงคำโฆษณา</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/cat-food-skin-coat-guide" class="read-link">อ่านคู่มือ →</a>
        </div>
      </div>
    </article>
    <article class="review-card">
      <div class="review-thumb" style="background:linear-gradient(135deg,#FFF7E6,#FFF0EB)">🏢</div>
      <div class="review-body">
        <div class="review-cat">มือใหม่ · เลี้ยงแมวในคอนโด</div>
        <h4>เลี้ยงแมวในคอนโดต้องมีอะไรบ้าง?</h4>
        <p>เช็กลิสต์ของจำเป็นสำหรับพื้นที่น้อย จัดโซนอาหาร น้ำ กระบะ ที่ลับเล็บ และพื้นที่สูงให้แมวอยู่สบาย</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/cat-condo-new-owner-checklist" class="read-link">อ่านเช็กลิสต์ →</a>
        </div>
      </div>
    </article>
  </div>
  <div style="text-align:center;margin-top:32px">
    <a href="/reviews" class="btn-outline">📋 ดูบทความและรีวิวทั้งหมด</a>
  </div>
</section>

<!-- REVIEW ARTICLES (data-driven) -->
<section class="section" id="reviews">
  <div class="section-header">
    <h2>📝 รีวิวสินค้าล่าสุดจาก mooma.online</h2>
    <p>อ่านรีวิวแบบละเอียด ก่อนตัดสินใจซื้อ</p>
  </div>
  <div class="review-grid">
    {featured.map(p => (
      <div class="review-card">
        <div class="review-thumb" style="background:#FFF0EB">{p.emoji}</div>
        <div class="review-body">
          <div class="review-cat">{categoryLabels[p.category] || 'สินค้าสัตว์เลี้ยง'}</div>
          <h4>{p.title}</h4>
          <p>{p.highlight.slice(0, 50)}...</p>
          <div class="review-meta">
            <span class="read-time">⏱ {(p.priority || 1) * 2 + 1} นาที</span>
            <a href={`/products/${p.slug}`} class="read-link">อ่านรีวิว →</a>
          </div>
        </div>
      </div>
    ))}
  </div>
  <div style="text-align:center;margin-top:32px">
    <a href="/reviews" class="btn-outline">📋 ดูรีวิวทั้งหมด</a>
  </div>
</section>

<!-- TRUST -->
<section class="section">
  <div class="section-header">
    <h2>ทำไมต้องอ่านรีวิวจาก mooma.online</h2>
  </div>
  <div class="trust-grid">
    <div class="trust-card">
      <div class="trust-icon">✅</div>
      <h4>คัดสินค้าที่หาซื้อได้จริง</h4>
      <p>ทุกรีวิวมีลิงก์ซื้อจริงจาก Shopee ไม่ต้องเสียเวลาหาเอง</p>
    </div>
    <div class="trust-card">
      <div class="trust-icon">📊</div>
      <h4>เปรียบเทียบจุดเด่น-ข้อควรรู้</h4>
      <p>บอกทั้งข้อดีและข้อควรรู้แบบตรงไปตรงมา ไม่อวยเกินจริง</p>
    </div>
    <div class="trust-card">
      <div class="trust-icon">⚡</div>
      <h4>ตัดสินใจได้ใน 3-5 นาที</h4>
      <p>ข้อมูลครบในหน้าเดียว — เหมาะกับ เจ้าของสัตว์เลี้ยงที่ไม่มีเวลาอ่านรีวิวเป็นสิบๆ อัน</p>
    </div>
  </div>
</section>

<!-- HOW WE REVIEW -->
<section class="section">
  <div class="section-header">
    <h2>🔍 เรารีวิวจากอะไร?</h2>
  </div>
  <div class="about-card" style="text-align:left;margin:0 auto">
    <ul style="list-style:none;padding:0;display:flex;flex-direction:column;gap:12px">
      <li style="display:flex;align-items:flex-start;gap:12px;font-size:0.95em;color:var(--gray-600)">
        <span style="font-size:1.3em;flex-shrink:0">📋</span>
        <span><strong style="color:var(--charcoal)">ดูจากคุณสมบัติสินค้า</strong> — ตรวจสอบ spec, ส่วนผสม, วัสดุ, และเทคโนโลยีที่ใช้จริง</span>
      </li>
      <li style="display:flex;align-items:flex-start;gap:12px;font-size:0.95em;color:var(--gray-600)">
        <span style="font-size:1.3em;flex-shrink:0">💰</span>
        <span><strong style="color:var(--charcoal)">ดูจากความคุ้มค่าเทียบกับปริมาณ</strong> — คำนวณความคุ้มค่าต่อหน่วย เช่น ความคุ้มค่าต่อ กก. หรือต่อการใช้งาน</span>
      </li>
      <li style="display:flex;align-items:flex-start;gap:12px;font-size:0.95em;color:var(--gray-600)">
        <span style="font-size:1.3em;flex-shrink:0">🐾</span>
        <span><strong style="color:var(--charcoal)">ดูจากความเหมาะสมกับหมา/แมวแต่ละแบบ</strong> — พันธุ์เล็ก พันธุ์ใหญ่ สูงวัย ลูกสัตว์ แพ้ง่าย</span>
      </li>
      <li style="display:flex;align-items:flex-start;gap:12px;font-size:0.95em;color:var(--gray-600)">
        <span style="font-size:1.3em;flex-shrink:0">⭐</span>
        <span><strong style="color:var(--charcoal)">ดูจากรีวิวผู้ซื้อจริงบน Shopee</strong> — อ่านแล้วสรุปภาพรวมคะแนนและปัญหาที่พบบ่อย</span>
      </li>
      <li style="display:flex;align-items:flex-start;gap:12px;font-size:0.95em;color:var(--gray-600)">
        <span style="font-size:1.3em;flex-shrink:0">📝</span>
        <span><strong style="color:var(--charcoal)">สรุปข้อดีข้อควรรู้แบบไม่อวยเกิน</strong> — บอกตรงๆ ว่าเหมาะกับใคร ไม่เหมาะกับใคร</span>
      </li>
    </ul>
  </div>
</section>

<!-- ABOUT -->
<section class="about-section" id="about">
  <div class="about-card">
    <h2>🐾 เกี่ยวกับ mooma.online</h2>
    <p>mooma.online คือเว็บรีวิวสินค้าสัตว์เลี้ยงสำหรับคนรักหมาแมว ที่อยากได้ของดี คุ้มค่า และข้อมูลที่ช่วยตัดสินใจได้จริง — เราเชื่อว่าสัตว์เลี้ยงทุกตัวสมควรได้รับของดีที่คุ้มค่าและจับต้องได้</p>
  </div>
</section>

</Layout>

<script>
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });
</script>
