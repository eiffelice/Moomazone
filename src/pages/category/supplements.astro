import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="อาหารเสริมสัตว์เลี้ยง — วิตามิน บำรุงขน บำรุงข้อ | mooma.online"
  description="คู่มืออาหารเสริมสัตว์เลี้ยง — วิตามินบำรุงขน กลูโคซามีนบำรุงข้อ โพรไบโอติก อาหารเสริมแมว อาหารเสริมสุนัข จาก Shopee"
  ogTitle="อาหารเสริมสัตว์เลี้ยง — วิตามิน บำรุงขน ข้อ | mooma.online"
  ogDescription="อาหารเสริมสำหรับหมาแมว — บำรุงขน บำรุงข้อ เสริมภูมิคุ้มกัน"
  ogType="website"
  ogUrl="https://mooma.online/category/supplements"
>
  <section class="section">
    <nav class="breadcrumb">
      <a href="/">หน้าแรก</a> ›
      <span>อาหารเสริม</span>
    </nav>

    <div class="section-header">
      <h1 style="font-size:1.8em">💊 อาหารเสริมสัตว์เลี้ยง</h1>
      <p>เสริมสุขภาพน้องจากภายใน — เลือกอาหารเสริมที่เหมาะกับปัญหา</p>
    </div>

    <p style="text-align:center;color:var(--gray-400);padding:48px 0;">
      🚧 กำลังรวบรวมรีวิวอาหารเสริม — กลับมาเร็วๆ นี้
    </p>

    <h2>🐾 อาหารเสริมที่พบบ่อย</h2>
    <div class="facts-grid" style="grid-template-columns:1fr 1fr">
      <div class="fact"><strong>🐟 โอเมก้า 3-6-9</strong> — บำรุงผิวหนังและขน ลดการอักเสบ ช่วยข้อ — จากน้ำมันปลา</div>
      <div class="fact"><strong>🦴 กลูโคซามีน</strong> — บำรุงข้อต่อ เหมาะกับสุนัขแก่หรือพันธุ์ใหญ่ที่มีปัญหาข้อเสื่อม</div>
      <div class="fact"><strong>🦠 โพรไบโอติก</strong> — เสริมระบบย่อย ลดท้องเสีย — โดยเฉพาะตอนเปลี่ยนอาหาร</div>
      <div class="fact"><strong>💇 ไบโอติน + Zinc</strong> — บำรุงขน ลดขนร่วง เสริมผิวหนังให้แข็งแรง</div>
      <div class="fact"><strong>🛡️ วิตามินรวม</strong> — สำหรับสัตว์ที่ไม่ได้รับสารอาหารครบจากอาหารหลัก</div>
      <div class="fact"><strong>🌿 Milk Thistle</strong> — บำรุงตับ — โดยเฉพาะสุนัขที่กินยาต่อเนื่อง</div>
    </div>

    <section class="faq" style="margin-top:32px">
      <h2>❓ คำถามที่พบบ่อย — อาหารเสริมสัตว์เลี้ยง</h2>
      <details>
        <summary>สัตว์เลี้ยงจำเป็นต้องกินอาหารเสริมไหม?</summary>
        <p>ถ้ากินอาหารครบถ้วนอยู่แล้ว — ไม่จำเป็น แต่ถ้ามีปัญหาเฉพาะ เช่น ขนร่วง ข้อเสื่อม ผิวแห้ง อาหารเสริมช่วยได้</p>
      </details>
      <details>
        <summary>ให้อาหารเสริมคนกับสัตว์เลี้ยงได้ไหม?</summary>
        <p>ไม่ควร — ปริมาณและส่วนผสมต่างกัน วิตามินบางตัวเป็นพิษต่อสัตว์ — ควรใช้อาหารเสริมสำหรับสัตว์โดยเฉพาะ</p>
      </details>
      <details>
        <summary>โอเมก้า 3 จากปลา กับจากพืช ต่างกันไหม?</summary>
        <p>โอเมก้า 3 จากปลา (EPA/DHA) ดูดซึมดีกว่าจากพืช (ALA) — สำหรับผิวหนังและข้อ แนะนำจากน้ำมันปลา</p>
      </details>
    </section>
  </section>
</Layout>