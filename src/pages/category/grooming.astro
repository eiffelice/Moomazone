---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import productsData from '../../data/products.json';

const categoryProducts = productsData.products.filter(p => p.category === 'grooming');
---

<Layout
  title="กรูมมิ่ง & ดูแลสุขอนามัยสัตว์เลี้ยง — แผ่นเช็ด ยาหยดหลัง แชมพู | mooma.online"
  description="รวมรีวิวของใช้ดูแลสุขอนามัยหมาแมวจาก Shopee — แผ่นเช็ดคราบน้ำตา ผ้าเช็ดหู ยาหยดหลัง แชมพู แปรงขน และอุปกรณ์กรูมมิ่ง"
  ogTitle="กรูมมิ่ง & ดูแลสุขอนามัยสัตว์เลี้ยง | mooma.online"
  ogDescription="แผ่นเช็ด ยาหยดหลัง แชมพู แปรงขน และของใช้ดูแลความสะอาดสำหรับหมาแมว"
  ogType="website"
  ogUrl="https://mooma.online/category/grooming"
>
  <section class="section">
    <nav class="breadcrumb">
      <a href="/">หน้าแรก</a> ›
      <span>กรูมมิ่ง & ดูแลสุขอนามัย</span>
    </nav>

    <div class="section-header">
      <h1 style="font-size:1.8em">✂️ กรูมมิ่ง & ดูแลสุขอนามัยสัตว์เลี้ยง</h1>
      <p>แผ่นเช็ด ยาหยดหลัง แชมพู แปรงขน และของใช้ดูแลความสะอาดน้องหมาน้องแมว</p>
    </div>

    <div class="product-grid">
      {categoryProducts.length > 0 ? (
        categoryProducts.map(p => (
          <ProductCard
            href={`/products/${p.slug}`}
            shopeeUrl={p.shopeeUrl}
            emoji={p.emoji}
            badge={p.badge}
            badgeClass={p.badgeClass}
            title={p.title}
            suitable={p.suitable}
            highlight={p.highlight}
            note={p.note}
            stars={p.stars}
            image={p.image || null}
          />
        ))
      ) : (
        <p style="grid-column:1/-1;text-align:center;color:var(--gray-400);padding:48px 0;">
          🚧 กำลังเพิ่มสินค้าใหม่ — กลับมาเช็กเร็วๆ นี้
        </p>
      )}
    </div>
  </section>

  <section class="section">
    <h2>🐾 ของดูแลสุขอนามัยที่ควรมี</h2>
    <div class="facts-grid" style="grid-template-columns:1fr 1fr">
      <div class="fact"><strong>🧻 แผ่นเช็ดสัตว์เลี้ยง</strong> — เช็ดตา ปาก หู หรือคราบสกปรกระหว่างวัน</div>
      <div class="fact"><strong>💧 ยาหยดหลัง</strong> — ดูแลเห็บหมัดตามรอบการใช้งานของสินค้า</div>
      <div class="fact"><strong>🪮 แปรงสลิกเกอร์</strong> — แปรงขนสำหรับสุนัข/แมวขนยาว แกะขนพันกัน</div>
      <div class="fact"><strong>💅 ที่ตัดเล็บ</strong> — ต้องคม จับถนัดมือ และตัดทีละน้อย</div>
      <div class="fact"><strong>🪥 ยาสีฟัน + แปรง</strong> — ใช้สูตรสำหรับสัตว์เลี้ยงเท่านั้น</div>
      <div class="fact"><strong>🧴 แชมพู</strong> — สูตรอ่อนโยน pH balanced สำหรับหมาแมว</div>
    </div>
  </section>

  <section class="faq">
    <h2>❓ คำถามที่พบบ่อย — กรูมมิ่ง & ดูแลสุขอนามัย</h2>
    <details>
      <summary>แผ่นเช็ดสัตว์เลี้ยงใช้แทนอาบน้ำได้ไหม?</summary>
      <p>ใช้เช็ดเฉพาะจุดหรือระหว่างวันได้ แต่ไม่ควรใช้แทนอาบน้ำทั้งหมด โดยเฉพาะสัตว์เลี้ยงที่สกปรกมากหรือมีกลิ่นตัวสะสม</p>
    </details>
    <details>
      <summary>ยาหยดหลังควรอยู่หมวดไหน?</summary>
      <p>จัดอยู่ในหมวดกรูมมิ่ง & ดูแลสุขอนามัย เพราะเป็นสินค้าดูแลเห็บหมัดและสุขอนามัยภายนอก ไม่ใช่อาหารหรือขนม</p>
    </details>
    <details>
      <summary>ตัดเล็บเองปลอดภัยไหม?</summary>
      <p>ปลอดภัยถ้ารู้วิธี — ตัดเฉพาะปลายเล็บทีละน้อย หลีกเลี่ยง Quick หรือเส้นเลือดในเล็บ ถ้าไม่แน่ใจให้กรูมเมอร์ทำให้</p>
    </details>
  </section>
</Layout>
