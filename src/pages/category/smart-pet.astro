---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';
import productsData from '../../data/products.json';
import { itemListSchema } from '../../utils/structuredData';

const categoryProducts = productsData.products.filter(p => p.category === 'smart-pet');
const structuredData = itemListSchema({
  name: 'Smart Pet — อุปกรณ์อัจฉริยะสำหรับสัตว์เลี้ยง',
  description: 'รวมรีวิวอุปกรณ์ Smart Pet — เครื่องให้อาหารอัตโนมัติ น้ำพุดื่มน้ำแมว กล้องดูสัตว์เลี้ยง GPS tracker อุปกรณ์ IoT สำหรับหมาแมว',
  url: 'https://mooma.online/category/smart-pet',
  products: categoryProducts,
  breadcrumbs: [
    { name: 'หน้าแรก', url: 'https://mooma.online' },
    { name: 'Smart Pet', url: 'https://mooma.online/category/smart-pet' },
  ],
});
---

<Layout
  title="Smart Pet — อุปกรณ์อัจฉริยะสำหรับสัตว์เลี้ยง | mooma.online"
  description="รวมอุปกรณ์ Smart Pet — เครื่องให้อาหารอัตโนมัติ น้ำพุดื่มน้ำแมว กล้องดูสัตว์เลี้ยง GPS tracker อุปกรณ์ IoT สำหรับหมาแมว"
  ogTitle="Smart Pet — อุปกรณ์อัจฉริยะสำหรับสัตว์เลี้ยง | mooma.online"
  ogDescription="อุปกรณ์อัจฉริยะสำหรับสัตว์เลี้ยง — ให้อาหารอัตโนมัติ กล้องดูน้อง น้ำพุแมว"
  ogType="website"
  ogUrl="https://mooma.online/category/smart-pet"
  structuredData={structuredData}
>
  <section class="section">
    <nav class="breadcrumb">
      <a href="/">หน้าแรก</a> ›
      <span>Smart Pet</span>
    </nav>

    <div class="section-header">
      <h1 style="font-size:1.8em">🤖 Smart Pet — อุปกรณ์อัจฉริยะ</h1>
      <p>เทคโนโลยีเพื่อน้อง — ดูแลสัตว์เลี้ยงได้แม้ไม่อยู่บ้าน</p>
    </div>

    <div class="product-grid">
      {categoryProducts.length > 0 ? (
        categoryProducts.map(p => (
          <ProductCard
            href={`/products/${p.slug}`}
            shopeeUrl={p.shopeeUrl}
            emoji={p.emoji}
            badge={p.badge}
            badgeClass={p.badgeClass}
            title={p.title}
            suitable={p.suitable}
            highlight={p.highlight}
            note={p.note}
            stars={p.stars}
            image={p.image || null}
          />
        ))
      ) : (
        <p style="grid-column:1/-1;text-align:center;color:var(--gray-400);padding:48px 0;">
          🚧 กำลังรวบรวมรีวิวอุปกรณ์ Smart Pet — กลับมาเร็วๆ นี้
        </p>
      )}
    </div>

    <h2>🐾 Smart Pet มีอะไรบ้าง?</h2>
    <div class="facts-grid" style="grid-template-columns:1fr 1fr">
      <div class="fact"><strong>🍽️ เครื่องให้อาหารอัตโนมัติ</strong> — ตั้งเวลาให้อาหารผ่านแอป เหมาะกับคนทำงานนอกบ้าน</div>
      <div class="fact"><strong>💧 น้ำพุดื่มน้ำ</strong> — น้ำหมุนเวียน กรองสะอาด ดึงดูดแมวให้ดื่มน้ำมากขึ้น</div>
      <div class="fact"><strong>📷 กล้องดูสัตว์เลี้ยง</strong> — ดูน้องผ่านมือถือ บางรุ่นมีเลเซอร์เล่นกับแมวได้</div>
      <div class="fact"><strong>📍 GPS Tracker</strong> — ติดปลอกคอ ติดตามตำแหน่งน้องหมาแมวแบบ real-time</div>
      <div class="fact"><strong>🚪 ประตูอัจฉริยะ</strong> — ประตูสัตว์เลี้ยงที่เปิดด้วย microchip</div>
      <div class="fact"><strong>🏠 Smart Litter Box</strong> — กระบะทรายอัตโนมัติ ทำความสะอาดเองหลังแมวใช้</div>
    </div>

    <section class="faq" style="margin-top:32px">
      <h2>❓ คำถามที่พบบ่อย — Smart Pet</h2>
      <details>
        <summary>เครื่องให้อาหารอัตโนมัติคุ้มค่าไหม?</summary>
        <p>คุ้มถ้าคุณทำงานนอกบ้านและไม่อยากให้น้องอด — ป้องกันการให้อาหารเกิน ลดความเสี่ยงโรคอ้วน</p>
      </details>
      <details>
        <summary>น้ำพุดื่มน้ำจำเป็นแค่ไหน?</summary>
        <p>แมวเป็นสัตว์ที่ไม่ค่อยดื่มน้ำนิ่ง — น้ำพุกระตุ้นให้แมวดื่มมากขึ้น ลดเสี่ยงโรคไตและนิ่ว</p>
      </details>
      <details>
        <summary>Smart Litter Box vs กระบะธรรมดา ต่างกันยังไง?</summary>
        <p>Smart Litter Box ทำความสะอาดอัตโนมัติหลังแมวใช้ — แต่ลงทุนสูงกว่ามาก (เริ่มต้นหลักหมื่นขึ้นไป)</p>
      </details>
    </section>
  </section>
</Layout>