---
import Layout from '../../layouts/Layout.astro';
import ShopeeSignupCTA from '../../components/ShopeeSignupCTA.astro';
import { productArticleSchema } from '../../utils/structuredData';

const productUrl = 'https://mooma.online/products/bite-of-wild-p42-cat-food';
const shopeeUrl = 'https://s.shopee.co.th/1100areaTP';
const heroImage = 'https://down-th.img.susercontent.com/file/cn-11134207-7ras8-mb3huz2qypx582.webp';
const gallery = [
  'https://down-th.img.susercontent.com/file/cn-11134207-7ras8-mb3huz2qypx582.webp',
  'https://down-th.img.susercontent.com/file/cn-11134207-820l4-mei23rl6ws1u73.webp',
  'https://down-th.img.susercontent.com/file/cn-11134207-820l4-mei23rl8idc1ba.webp',
  'https://down-th.img.susercontent.com/file/cn-11134207-820l4-mei23rl780lj14.webp',
  'https://down-th.img.susercontent.com/file/cn-11134207-820l4-mei23rl8gyrl83.webp',
