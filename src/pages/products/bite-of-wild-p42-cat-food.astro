  'https://down-th.img.susercontent.com/file/cn-11134207-820l4-mei23rlbcwskba.webp',
];

const structuredData = productArticleSchema({
  title: 'รีวิว Bite of Wild อาหารแมว P42 5 กก. Grain Free โปรตีน 42%',
  description: 'รีวิว Bite of Wild อาหารแมว Holistic P42 ขนาด 5 กก. Grain Free โปรตีน 42% ผสมฟรีซดรายไก่ แซลมอน ตับและหัวใจไก่ เหมาะกับแมวทุกช่วงวัย',
  url: productUrl,
  image: heroImage,
  product: {
    name: 'Bite of Wild อาหารแมว P42 5 กก. Grain Free โปรตีน 42%',
