  ],
  breadcrumbs: [
    { name: 'หน้าแรก', url: 'https://mooma.online' },
    { name: 'อาหารแมว', url: 'https://mooma.online/category/cat-food' },
    { name: 'Bite of Wild P42', url: productUrl },
  ],
