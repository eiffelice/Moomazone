  </section>

  <div class="product-gallery">
    {gallery.map((src, index) => (
      <img src={src} alt={`Bite of Wild P42 อาหารแมว Grain Free รูปที่ ${index + 1}`} onclick="openLightbox(this.src)" loading="lazy" />
