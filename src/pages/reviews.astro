---
import Layout from '../layouts/Layout.astro';
import productsData from '../data/products.json';
import { itemListSchema } from '../utils/structuredData';

const structuredData = itemListSchema({
  name: 'รีวิวสินค้าสัตว์เลี้ยงทั้งหมด',
  description: 'รวมรีวิวสินค้าสัตว์เลี้ยงทั้งหมดจาก mooma.online — อาหาร กระบะทราย คอนโดแมว ขนม ของใช้หมาแมว',
  url: 'https://mooma.online/reviews',
  products: productsData.products,
  breadcrumbs: [
    { name: 'หน้าแรก', url: 'https://mooma.online' },
    { name: 'รีวิวทั้งหมด', url: 'https://mooma.online/reviews' },
  ],
});
---
<Layout
  title="รีวิวสินค้าสัตว์เลี้ยงทั้งหมด | mooma.online"
  description="รวมรีวิวสินค้าสัตว์เลี้ยงทั้งหมดจาก mooma.online — อาหาร กระบะทราย คอนโดแมว ขนม ของใช้หมาแมว"
  ogUrl="https://mooma.online/reviews"
  structuredData={structuredData}
>
<section class="section">
  <div class="section-header">
    <h1 style="font-size:1.8em">📝 รีวิวทั้งหมด</h1>
    <p>ทุกรีวิวจาก mooma.online</p>
  </div>
  <div class="review-grid">
    <div class="review-card">
      <div class="review-thumb" style="background:#FFF0EB">🐶</div>
      <div class="review-body">
        <div class="review-cat">คู่มือสุนัข 🆕</div>
        <h4>หมาไม่ค่อยกินข้าว ทำยังไงดี?</h4>
        <p>เช็กสุขภาพ พฤติกรรม กลิ่นอาหาร และวิธีเปลี่ยนอาหาร...</p>
        <div class="review-meta">
          <span class="read-time">⏱ 7 นาที</span>
          <a href="/articles/dog-not-eating-guide" class="read-link">อ่านบทความ →</a>
        </div>
      </div>
    </div>
    <div class="review-card">
      <div class="review-thumb" style="background:#FFF5F0">🦷</div>
      <div class="review-body">
        <div class="review-cat">คู่มือสุนัข 🆕</div>
        <h4>ขนมขัดฟันสุนัขจำเป็นไหม?</h4>
        <p>วิธีเลือกขนาด เนื้อสัมผัส และข้อควรระวังในการดูแลฟัน...</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/dog-dental-chews-guide" class="read-link">อ่านบทความ →</a>
        </div>
      </div>
    </div>
    <div class="review-card">
      <div class="review-thumb" style="background:#EBF7FF">😬</div>
      <div class="review-body">
        <div class="review-cat">คู่มือสุนัข 🆕</div>
        <h4>หมากลิ่นปากแรง แก้ยังไง?</h4>
        <p>เช็กคราบฟัน เหงือก อาหาร และสัญญาณที่ควรพบสัตวแพทย์...</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/dog-bad-breath-solution" class="read-link">อ่านบทความ →</a>
        </div>
      </div>
    </div>
    <div class="review-card">
      <div class="review-thumb" style="background:#E8F5E9">👃</div>
      <div class="review-body">
        <div class="review-cat">คู่มือแมว 🆕</div>
        <h4>แมวฉี่เหม็นมาก แก้ยังไง?</h4>
        <p>เช็กต้นเหตุกลิ่นฉี่แมว กระบะ จุดวาง และสัญญาณสุขภาพ...</p>
        <div class="review-meta">
          <span class="read-time">⏱ 7 นาที</span>
          <a href="/articles/cat-pee-smell-solution" class="read-link">อ่านบทความ →</a>
        </div>
      </div>
    </div>
    <div class="review-card">
      <div class="review-thumb" style="background:#F5F0FF">🐟</div>
      <div class="review-body">
        <div class="review-cat">อาหารแมว 🆕</div>
        <h4>อาหารแมวช่วยเรื่องขนร่วง ผิวหนัง และขนสวย เลือกยังไงดี</h4>
        <p>ดูสารอาหารสำคัญ โปรตีน โอเมก้า ไบโอติน Zinc...</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/cat-food-skin-coat-guide" class="read-link">อ่านบทความ →</a>
        </div>
      </div>
    </div>
    <div class="review-card">
      <div class="review-thumb" style="background:#FFF7E6">🏢</div>
      <div class="review-body">
        <div class="review-cat">มือใหม่เลี้ยงแมว 🆕</div>
        <h4>เลี้ยงแมวในคอนโดต้องมีอะไรบ้าง?</h4>
        <p>เช็กลิสต์ของจำเป็นสำหรับพื้นที่น้อย เริ่มครบแบบไม่ซื้อเกิน...</p>
        <div class="review-meta">
          <span class="read-time">⏱ 6 นาที</span>
          <a href="/articles/cat-condo-new-owner-checklist" class="read-link">อ่านบทความ →</a>
        </div>
      </div>
    </div>
    <div class="review-card">
      <div class="review-thumb" style="background:#FFF0EB">🐶</div>
      <div class="review-body">
        <div class="review-cat">อาหารสุนัข</div>
        <h4>Kin-D กินดี อาหารสุนัข 20 กก. สูตรเนื้อ</h4>
        <p>โปรตีน 18% คุ้มค่า รับรองโดยสัตวแพทย์...</p>
