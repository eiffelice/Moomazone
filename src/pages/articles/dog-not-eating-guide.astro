---
import Layout from '../../layouts/Layout.astro';
import ShopeeSignupCTA from '../../components/ShopeeSignupCTA.astro';
import { productArticleSchema } from '../../utils/structuredData';

const faqs = [
  { question: 'หมาไม่ค่อยกินข้าวต้องพาไปหาหมอไหม?', answer: 'ถ้าไม่กินเกิน 24 ชั่วโมง ซึม อาเจียน ท้องเสีย หายใจผิดปกติ หรือมีโรคประจำตัว ควรพาไปพบสัตวแพทย์ทันที แต่ถ้ายังกินขนม เล่นปกติ และเพิ่งเปลี่ยนอาหาร อาจเริ่มจากเช็กอาหารและสภาพแวดล้อมก่อน' },
  { question: 'เปลี่ยนอาหารสุนัขทันทีได้ไหม?', answer: 'ไม่ควรเปลี่ยนทันที เพราะอาจทำให้ท้องเสียหรือยิ่งไม่กิน ควรค่อยๆ ผสมอาหารใหม่กับอาหารเดิมหลายวันและสังเกตอุจจาระกับพฤติกรรม' },
  { question: 'สุนัขเลือกกินเพราะนิสัยหรือป่วย?', answer: 'เป็นได้ทั้งสองแบบ ถ้ายังกระตือรือร้นและกินของโปรดได้ อาจเป็นเรื่องพฤติกรรมหรือเบื่ออาหาร แต่ถ้ามีอาการซึม น้ำหนักลด หรือเจ็บปาก ควรตรวจสุขภาพ' },
  { question: 'ควรเติมท็อปปิ้งให้อาหารไหม?', answer: 'ทำได้เป็นบางครั้ง เช่น เติมน้ำอุ่นหรืออาหารเปียกเล็กน้อยเพื่อเพิ่มกลิ่น แต่ไม่ควรตามใจจนหมารอแต่ท็อปปิ้ง เพราะจะทำให้เลือกกินหนักขึ้น' },
];

const structuredData = productArticleSchema({
  title: 'หมาไม่ค่อยกินข้าว ทำยังไงดี? สาเหตุและวิธีเลือกอาหารให้เหมาะ',
  description: 'คู่มือสำหรับเจ้าของสุนัขที่หมาไม่ค่อยกินข้าว ไล่เช็กสาเหตุ สุขภาพ พฤติกรรม วิธีเปลี่ยนอาหาร และแนวทางเลือกอาหารสุนัขที่เหมาะกว่าเดิม',
  url: 'https://mooma.online/articles/dog-not-eating-guide',
  image: 'https://mooma.online/og-default-v2.png',
  datePublished: '2026-05-23',
  dateModified: '2026-05-23',
  faqs,
  breadcrumbs: [
    { name: 'หน้าแรก', url: 'https://mooma.online' },
    { name: 'อาหารสุนัข', url: 'https://mooma.online/category/dog-food' },
    { name: 'หมาไม่ค่อยกินข้าว', url: 'https://mooma.online/articles/dog-not-eating-guide' },
  ],
});
---

<Layout
  title="หมาไม่ค่อยกินข้าว ทำยังไงดี? สาเหตุและวิธีเลือกอาหาร"
  description="หมาไม่ค่อยกินข้าวเกิดจากอะไร? เช็กสาเหตุ สุขภาพ พฤติกรรม วิธีเปลี่ยนอาหาร และแนวทางเลือกอาหารสุนัขให้เหมาะกับน้อง"
  ogTitle="หมาไม่ค่อยกินข้าว ทำยังไงดี?"
  ogDescription="คู่มือไล่เช็กสาเหตุหมาเบื่ออาหาร พร้อมวิธีปรับมื้ออาหารและเลือกอาหารสุนัขให้เหมาะ"
  ogType="article"
  ogUrl="https://mooma.online/articles/dog-not-eating-guide"
  structuredData={structuredData}
>
<article class="product-review">
  <nav class="breadcrumb">
    <a href="/">หน้าแรก</a> ›
    <a href="/category/dog-food">อาหารสุนัข</a> ›
    <span>หมาไม่ค่อยกินข้าว</span>
  </nav>

  <section class="product-hero">
    <h1>🐶 หมาไม่ค่อยกินข้าว ทำยังไงดี? สาเหตุและวิธีเลือกอาหารให้เหมาะ</h1>
    <p class="subtitle">ถ้าน้องหมาเริ่มเมินชามอาหาร อย่าเพิ่งรีบเปลี่ยนอาหารมั่วๆ ให้ไล่เช็กสุขภาพ พฤติกรรม กลิ่นอาหาร และวิธีให้อาหารก่อน</p>
  </section>

  <section class="quick-facts">
    <h2>📋 เช็กเร็ว: หมาไม่กินข้าวควรดูอะไรบ้าง</h2>
    <div class="facts-grid">
      <div class="fact"><strong>สุขภาพ:</strong> ซึม อาเจียน ท้องเสีย หรือเจ็บปากต้องระวัง</div>
      <div class="fact"><strong>อาหาร:</strong> กลิ่นจาง เหม็นหืน หรือเม็ดใหญ่เกินไปทำให้ไม่อยากกิน</div>
      <div class="fact"><strong>พฤติกรรม:</strong> ให้ขนมหรืออาหารคนบ่อย อาจทำให้รอของอร่อยกว่า</div>
      <div class="fact"><strong>ตารางมื้อ:</strong> วางชามทั้งวันอาจทำให้กินไม่เป็นเวลา</div>
      <div class="fact"><strong>สภาพแวดล้อม:</strong> เสียงดัง เครียด หรือมีสัตว์ตัวอื่นแย่งพื้นที่</div>
      <div class="fact"><strong>การเปลี่ยนอาหาร:</strong> ค่อยๆ ผสม ไม่เปลี่ยนฉับพลัน</div>
    </div>
  </section>

  <section class="content-section">
    <h2>1) แยกก่อนว่า “ไม่กินเพราะป่วย” หรือ “เลือกกิน”</h2>
    <p>ถ้าน้องหมาไม่กินข้าวร่วมกับอาการซึม อาเจียน ท้องเสีย ไอ หอบ น้ำหนักลด หรือมีกลิ่นปากแรงผิดปกติ ควรพบสัตวแพทย์ เพราะอาจไม่ใช่แค่เบื่ออาหาร แต่เกี่ยวกับฟัน เหงือก ทางเดินอาหาร หรือโรคอื่นๆ</p>
    <p>แต่ถ้ายังกระดิกหาง เล่นได้ กินขนมได้ และเลือกกินเฉพาะอาหารบางแบบ ปัญหาอาจอยู่ที่พฤติกรรม ตารางมื้อ หรืออาหารไม่ดึงดูดพอ</p>
  </section>

  <section class="content-section">
    <h2>2) อย่าวางชามทั้งวัน ลองฝึกตารางมื้อ</h2>
    <p>การวางอาหารไว้ทั้งวันทำให้น้องหมาไม่เห็นคุณค่าของมื้ออาหาร และอาหารอาจเสียกลิ่นหรือโดนความชื้น ลองวางชาม 15-20 นาที ถ้าไม่กินให้เก็บ แล้วให้ใหม่ตามมื้อถัดไป วิธีนี้ช่วยให้สุนัขเรียนรู้เวลามื้ออาหารชัดขึ้น</p>
  </section>

  <section class="content-section">
    <h2>3) เช็กคุณภาพอาหารและขนาดเม็ด</h2>
    <p>อาหารที่เปิดถุงนาน กลิ่นจาง หรือเก็บไม่สนิทอาจทำให้หมาไม่สนใจ นอกจากนี้สุนัขพันธุ์เล็กหรือสุนัขสูงวัยอาจไม่ชอบเม็ดใหญ่และแข็งเกินไป ควรเลือกอาหารให้เหมาะกับวัย ขนาดตัว และสภาพฟัน</p>
    <p>ถ้าต้องการดูตัวอย่างอาหารสุนัขแบบอ่านง่าย ไปที่หมวด <a href="/category/dog-food">อาหารสุนัข</a> หรืออ่านรีวิว <a href="/products/kin-d-dog-food">Kin-D กินดี อาหารสุนัขสูตรเนื้อ</a> เพื่อใช้เป็นจุดเริ่มต้นในการเทียบจุดเด่นและข้อควรรู้</p>
  </section>

  <section class="content-section">
    <h2>4) เติมกลิ่นได้ แต่อย่าตามใจจนเลือกกินหนักขึ้น</h2>
    <p>การเติมน้ำอุ่นเล็กน้อยช่วยให้กลิ่นอาหารชัดขึ้นและทำให้อาหารนุ่มลง เหมาะกับสุนัขที่เริ่มเบื่อหรือมีปัญหาเคี้ยว แต่ควรหลีกเลี่ยงการเติมอาหารคนรสจัด เพราะเสี่ยงต่อสุขภาพและทำให้น้องรอแต่ของอร่อยกว่าเดิม</p>
  </section>

  <section class="content-section">
    <h2>5) ถ้าเปลี่ยนอาหาร ให้เปลี่ยนแบบค่อยเป็นค่อยไป</h2>
    <ol>
      <li>เริ่มผสมอาหารใหม่ในปริมาณน้อยกับอาหารเดิม</li>
      <li>ค่อยๆ เพิ่มสัดส่วนอาหารใหม่ตามการยอมรับของน้อง</li>
      <li>สังเกตอุจจาระ ผิวหนัง และพลังงานในแต่ละวัน</li>
      <li>ถ้าท้องเสียหรือคันผิดปกติ ให้หยุดและปรึกษาสัตวแพทย์</li>
    </ol>
  </section>

  <section class="content-section">
    <h2>6) ปัญหาช่องปากก็ทำให้ไม่อยากกินได้</h2>
    <p>สุนัขที่เจ็บฟัน เหงือกอักเสบ หรือมีคราบหินปูนเยอะ อาจอยากกินแต่เคี้ยวแล้วเจ็บ ถ้ามีกลิ่นปากร่วมด้วย อ่านต่อที่ <a href="/articles/dog-bad-breath-solution">หมากลิ่นปากแรง แก้ยังไง</a> และ <a href="/articles/dog-dental-chews-guide">ขนมขัดฟันสุนัขจำเป็นไหม</a></p>
  </section>

  <section class="content-section">
    <h2>คำถามที่พบบ่อย</h2>
    {faqs.map((faq) => (
      <details>
        <summary>{faq.question}</summary>
        <p>{faq.answer}</p>
      </details>
    ))}
  </section>

  <section class="content-section" style="border-top:1px solid var(--gray-100);padding-top:24px;margin-top:40px;">
    <h2>🐶 อ่านต่อที่เกี่ยวข้อง</h2>
    <ul>
      <li><a href="/category/dog-food">หมวดอาหารสุนัข</a></li>
      <li><a href="/products/kin-d-dog-food">รีวิว Kin-D กินดี อาหารสุนัขสูตรเนื้อ</a></li>
      <li><a href="/products/gentle-paws-dental-chews">รีวิว Gentle Paws Dental Chews</a></li>
    </ul>
    <p style="font-size:0.86em;color:var(--gray-400);">หมายเหตุ: บางลิงก์เป็น Affiliate</p>
  </section>

  <ShopeeSignupCTA />
</article>
</Layout>
