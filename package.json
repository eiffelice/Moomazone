{
  "name": "mooma-online",
  "type": "module",
  "version": "2.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "check": "astro check",
    "validate": "bash scripts/no-price-check.sh && bash scripts/check-disclosure.sh",
    "prebuild": "npm run validate",
    "build": "astro build && node scripts/alias-sitemap.mjs",
    "health": "node scripts/check-site-health.mjs",
    "health:external": "CHECK_EXTERNAL=1 node scripts/check-site-health.mjs",
    "preview": "astro preview",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^5.9.3"
  }
}
